# App Settings
APP_NAME=personal-command-bridge
ENVIRONMENT=development
LOG_LEVEL=INFO
USER_NAME=owner
APP_PORT=4567

# Telegram Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_CHAT_ID=your_chat_id

# WhatsApp Settings
WHATSAPP_MODE=bridge
WHATSAPP_ALLOWED_SENDER=your_phone_number
BRIDGE_PORT=3000

# Microsoft / OneDrive Settings
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:6060
ONEDRIVE_ROOT_PATH=

# Persistence
DATABASE_URL=sqlite:///data/app.db
MAX_RESULTS=10
MIRROR_ENABLED=true
